# General Vault Configuration=
export VAULT_ADDR="http://127.0.0.1:8200"
export VAULT_UNSEAL_KEY_1="your-unseal-key-1"
export VAULT_UNSEAL_KEY_2="your-unseal-key-2"
export VAULT_UNSEAL_KEY_3="your-unseal-key-3"
export VAULT_ROOT_TOKEN="your-root-token"

# Environment Configuration=
export ENVIRONMENT="dev"  # Change this to 'staging' or 'prod' as needed

# PostgreSQL Configuration=
export POSTGRES_DB="your_postgres_db"
export POSTGRES_USER="myuser"
export POSTGRES_PASSWORD="aNX5zFK9OIOPbcgzuQ2IZA=="

# AWS Configuration=
export AWS_ACCESS_KEY="your-aws-access-key"
export AWS_SECRET_KEY="your-aws-secret-key"
export AWS_REGION="your-aws-region"

# RabbitMQ Configuration=
export RABBITMQ_USER="your-rabbitmq-user"
export RABBITMQ_PASSWORD="your-rabbitmq-password"
export RABBITMQ_SERVER_NAME="rabbitmq"

# ElasticSearch Configuration=
export ELASTIC_PASSWORD="your-elastic-password"

# MinIO Configuration=
export MINIO_ACCESS_KEY="your-minio-user"
export MINIO_SECRET_KEY="your-minio-password"
export MINIO_ENDPOINT="localhost:9000"
export MINIO_BUCKET_NAME="your-bucket-name"
export MINIO_SECURE="false"

# JWT Configuration=
export JWT_KEY="xjYwJC+7le/P6UD3NeMVC5097nuqWjpC/yUCmfuG/k0="

# Recaptcha Configuration=
export RECAPTCHA_SECRET_KEY="6LcZLxQqAAAAAHQ1YkkdQbVP3cDD7RBLDkrNtoW0"

# Stripe Configuration=
export STRIPE_SECRET_KEY="your_stripe_secret_key"
export STRIPE_PUBLISHABLE_KEY="your_stripe_publishable_key"
export STRIPE_WEBHOOK_SECRET="your_stripe_webhook_secret"

# Azure Blob Storage Configuration=
export AZURE_CONNECTION_STRING="UseDevelopmentStorage=true"
export AZURE_CONTAINER_NAME="your-container-name"

# Local File Storage Configuration=
export LOCAL_FILE_STORAGE_DIRECTORY="/app/uploads"

# MassTransit RabbitMQ SSL Configuration=
export MASS_TRANSIT_RABBITMQ_SSL_ENABLED="true"
export RABBITMQ_CERTIFICATE_PATH="/etc/ssl/certs/rabbitmq.crt"
export RABBITMQ_CERTIFICATE_PASSPHRASE="your-certificate-passphrase"
export USE_CERTIFICATE_AS_AUTHENTICATION="true"
