	  attnum > 0 AND     -- Don't load system attributes
	  NOT attisdropped
	ORDER BY typ.oid, att.attnum;
	
	-- Load enum fields
	SELECT pg_type.oid, enumlabel
	FROM pg_enum
	JOIN pg_type ON pg_type.oid=enumtypid
	ORDER BY oid, enumsortorder;
	
