	FROM pg_type AS typ
	JOIN pg_namespace AS ns ON (ns.oid = typ.typnamespace)
	JOIN pg_class AS cls ON (cls.oid = typ.typrelid)
	JOIN pg_attribute AS att ON (att.attrelid = typ.typrelid)
